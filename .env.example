# ─── IDENTITÉ ───────────────────────────────────────────────────────────────
BOT_NAME=MonAssistant
USER_NAME=TonPrénom

# ─── TELEGRAM ──────────────────────────────────────────────────────────────
# Récupère ton token via @BotFather sur Telegram
TELEGRAM_TOKEN=xxxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyy
# Ton user_id Telegram (envoie /start à @userinfobot pour l'obtenir)
# Plusieurs IDs possibles séparés par des virgules
ALLOWED_USER_IDS=123456789

# ─── LLM API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
LLM_MODEL=claude-opus-4-7
LLM_MAX_TOKENS=4096

# ─── OPENAI (transcription vocale via Whisper) ─────────────────────────────
OPENAI_API_KEY=sk-xxxxx

# ─── GOOGLE APIs ───────────────────────────────────────────────────────────
# Crée un projet sur https://console.cloud.google.com
# Active : Gmail API, Calendar API, People API, Drive API
# Télécharge credentials.json dans le dossier du projet
# Au premier lancement, le flow OAuth s'ouvrira dans ton navigateur

# ─── BLAND.AI (appels téléphoniques IA — optionnel) ────────────────────────
# https://www.bland.ai/
BLAND_API_KEY=

# ─── TWILIO (SMS/WhatsApp — optionnel) ─────────────────────────────────────
# https://www.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ─── GITHUB (monitoring de repos — optionnel) ──────────────────────────────
# Personal Access Token classique avec scope "repo"
GITHUB_TOKEN=

# ─── APPLE NOTES (macOS uniquement) ────────────────────────────────────────
# Si tu tournes sur macOS et veux activer la création de notes iCloud
ENABLE_APPLE_NOTES=false

# ─── BACKUP (optionnel — pour déploiement VPS) ─────────────────────────────
# Backblaze B2 pour sauvegardes distantes quotidiennes
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
BACKUP_ENCRYPTION_KEY=
